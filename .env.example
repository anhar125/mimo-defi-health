# Xiaomi MiMo API
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_URL=https://api.mimo.xiaomi.com/v2.5

# On-chain Data Source
DEFILLAMA_API_KEY=your_defillama_api_key_here

# Monitoring Configuration
POLL_INTERVAL=60
PROTOCOLS=aave,compound,makerdao,lido,curve,uniswap
MONITORED_CHAINS=ethereum,arbitrum,optimism,polygon

# Anomaly Detection Thresholds
TVL_DROP_THRESHOLD_PCT=5.0
UTILIZATION_SPIKE_THRESHOLD=85.0
YIELD_ANOMALY_ZSCORE=2.5
CONFIDENCE_THRESHOLD=0.7

# Alert Channels (comma-separated: slack, telegram, pagerduty, webhook)
ALERT_CHANNELS=slack

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# PagerDuty
PAGERDUTY_ROUTING_KEY=your_routing_key_here

# Webhooks
ALERT_WEBHOOK_URL=https://your-webhook-endpoint.com/alerts

# MiMo Reasoning Settings
MIMO_MAX_REASONING_STEPS=15
MIMO_TEMPERATURE=0.1
MIMO_MAX_TOKENS=1024

# Application
DRY_RUN=false
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/defi_monitor.db
